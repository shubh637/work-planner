{
  "name": "work-planner-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:backend": "cd ../work-planner-backend && mvn spring-boot:run",
    "start:all": "npm run start:backend & npm run dev",
    "kill": "lsof -ti:8080,5173 | xargs kill -9 || true",
    "restart": "npm run kill && npm run start:all",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/browser": "^4.1.8",
    "axios-mock-adapter": "^2.1.0",
    "jsdom": "^29.1.1",
    "vite": "^5.2.12",
    "vitest": "^4.1.8"
  }
}
