{
  "name": "work-planner-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:backend": "cd ../work-planner-backend && mvn spring-boot:run",
    "start:frontend": "cd  ../work-panner-frontend && npm run dev",
    "start:all": "npm run start:backend & npm run dev",
    "kill": "lsof -ti:8080,5173 | xargs kill -9 || true",
    "restart": "npm run kill && npm run start:all"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.2.12"
  }
}
